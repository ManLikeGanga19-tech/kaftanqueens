# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Daraja (M-Pesa) ───────────────────────────────────────────────────────────
# All values are from your Safaricom Developer Portal (developer.safaricom.co.ke)

# "sandbox" for testing, "production" for live payments
DARAJA_ENV="sandbox"

# App credentials from the portal (Apps tab → your app → Keys & OAuth)
DARAJA_CONSUMER_KEY="GEMpDoYdyTf8QbEouhcmqsJwzVjeG8agG2cYAJUTn0G5xirH"
DARAJA_CONSUMER_SECRET="EPTQ5n7ZPjmhN59TeRMMWpTfRFyVvob9eM6KJ1aiggdOKc5y71aYmfaGWduuEDXT"

# The paybill / till number assigned to your app
DARAJA_SHORTCODE="174379"

# Lipa Na M-Pesa Online passkey (from the Daraja portal)
DARAJA_PASSKEY="bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919"

