{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An e-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["traditional", "modern"] },
        "price": { "type": "number" },
        "currencies": { "type": "object" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "delivered"] },
        "mpesaTransactionId": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "deliveryEstimate": { "type": "string" },
        "address": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "A user's wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "browsingHistory": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store of kaftan products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific product"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/wishlists/{userId}": {
      "schema": "Wishlist",
      "description": "User specific wishlists"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings"
    }
  }
}
